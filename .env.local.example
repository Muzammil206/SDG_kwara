# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# No Mapbox token needed — MapLibre uses free OpenFreeMap tiles
# To use a custom tile server, set this:
# NEXT_PUBLIC_MAP_TILE_URL=https://your-tile-server/styles/streets/style.json
